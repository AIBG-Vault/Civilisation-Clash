{
  "name": "civilization-clash-server",
  "description": "WebSocket server for AIBG Civilization Clash",
  "scripts": {
    "start": "node server.js",
    "test": "node --test tests/*.test.js",
    "format": "prettier --write \"../**/*.{js,json,md,html,css}\" --ignore-path ../.prettierignore",
    "format:check": "prettier --check \"../**/*.{js,json,md,html,css}\" --ignore-path ../.prettierignore",
    "prepare": "cd .. && husky install server/.husky"
  },
  "dependencies": {
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "prettier": "^3.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0"
  },
  "lint-staged": {
    "../**/*.{js,json,md,html,css}": [
      "prettier --write --ignore-path ../.prettierignore --config ../.prettierrc"
    ]
  }
}